# ===== LLM provider (OpenAI) =====
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.5
LLM_REASONING_EFFORT=xhigh
LLM_TEXT_VERBOSITY=low
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_REASONING_EFFORT=xhigh
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_SECRET_TTL=300

OPENAI_API_KEY=
# ANTHROPIC_API_KEY=   # optional; provider is swappable via init_chat_model

# ===== W&B Weave (required for tracing — judges inspect this project) =====
WANDB_API_KEY=
WANDB_PROJECT=atlas-finance-os
# WANDB_ENTITY=your-wandb-username-or-team
# WANDB_SANDBOX_ID=
# WANDB_SANDBOX_URL=

# ===== Redis (Redis Stack — search/JSON/vector) =====
REDIS_URL=redis://localhost:6379

# ===== Agent server =====
PORT=8123
AGENT_URL=http://localhost:8123
NEXT_PUBLIC_AGENT_URL=http://localhost:8123
