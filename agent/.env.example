# ===== LLM provider (OpenAI) =====
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

OPENAI_API_KEY=
# ANTHROPIC_API_KEY=   # optional; provider is swappable via init_chat_model

# ===== W&B Weave (required for tracing — judges inspect this project) =====
WANDB_API_KEY=
WANDB_PROJECT=atlas-finance-os
# WANDB_ENTITY=your-wandb-username-or-team

# ===== Redis (Redis Stack — search/JSON/vector) =====
REDIS_URL=redis://localhost:6379

# ===== Agent server =====
PORT=8123
