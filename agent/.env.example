# ===== LLM provider (OpenAI) =====
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.5
LLM_REASONING_EFFORT=xhigh
LLM_TEXT_VERBOSITY=low
OPENAI_SERVICE_TIER=priority
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_REASONING_EFFORT=xhigh
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_SECRET_TTL=300

OPENAI_API_KEY=
# ANTHROPIC_API_KEY=   # optional; provider is swappable via init_chat_model

# ===== W&B Weave (required for tracing — judges inspect this project) =====
WANDB_API_KEY=
WANDB_PROJECT=atlas-finance-os
# WANDB_ENTITY=your-wandb-username-or-team
# WANDB_SANDBOX_ID=
# WANDB_SANDBOX_URL=

# ===== Redis (Redis Stack — search/JSON/vector) =====
REDIS_URL=redis://localhost:6379

# ===== Agent server =====
PORT=8123
AGENT_URL=http://localhost:8123
NEXT_PUBLIC_AGENT_URL=http://localhost:8123

# ===== Finance-operations connectors (OPTIONAL; not required for the core demo) =====
# Each connector ingests a CSV or JSON export. If a variable is unset the connector
# reports "not configured" with a blocker and never invents data. To try the feature
# with the bundled Acme demo fixtures instead, run:  scripts/import-operations.sh --demo
# ATLAS_LEDGER_FILE=/abs/path/to/general_ledger.csv
# ATLAS_INVOICES_FILE=/abs/path/to/accounts_payable.csv
# ATLAS_VENDOR_EXPORT_FILE=/abs/path/to/vendor_contracts.json
# ATLAS_CRM_FILE=/abs/path/to/crm_opportunities.csv
# ATLAS_HEADCOUNT_FILE=/abs/path/to/headcount_plan.csv
# ATLAS_SECURITY_FILE=/abs/path/to/security_evidence.json
# ATLAS_BOARD_POLICY_FILE=/abs/path/to/board_policies.json
